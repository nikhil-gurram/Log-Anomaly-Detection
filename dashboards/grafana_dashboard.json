      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "alias": "PowerShell Process Frequency",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": 1
              },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "query": "source:sysmon-csv AND (process.name:powershell.exe OR message:*powershell* OR Message:*powershell*)",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "PowerShell Execution Frequency",
      "type": "timeseries"
    },
