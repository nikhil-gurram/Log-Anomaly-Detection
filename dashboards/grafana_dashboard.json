      "targets": [
        {
          "alias": "Process Activity (EventID 1 or 5)",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": 0,
                "trimEdges": 0
              },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "query": "source:sysmon-csv AND (EventID:(1 OR 5) OR winlog.event_id:(1 OR 5) OR event.code:(\"1\" OR \"5\"))",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Process Activity",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch-SOC"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "red",
