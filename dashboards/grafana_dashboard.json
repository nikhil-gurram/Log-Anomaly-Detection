              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": 0
              },
              "type": "date_histogram"
            }
          ],
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "query": "source:sysmon-csv AND (EventID:11 OR winlog.event_id:11 OR event.code:\"11\")",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "File Creation Spikes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch-SOC"
