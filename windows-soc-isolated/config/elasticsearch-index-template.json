{
  "index_patterns": ["ml-anomalies-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "refresh_interval": "5s"
    },
    "mappings": {
      "properties": {
        "timestamp": { "type": "date" },
        "event_id": { "type": "integer" },
        "event_type": { "type": "keyword" },
        "anomaly_score": { "type": "float" },
        "prediction": { "type": "keyword" },
        "message": { "type": "text" },
        "source": { "type": "keyword" }
      }
    }
  },
  "priority": 500,
  "version": 1,
  "_meta": {
    "description": "Template for machine learning anomaly alerts"
  }
}
